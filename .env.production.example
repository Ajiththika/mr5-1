# MR5 School — AWS Production Environment Template

# Copy values into AWS Secrets Manager (JSON key per secret) and ECS task environment.
# Do NOT commit this file with real values.

# =============================================================================
# FRONTEND (ECS task: mr5-web) — build-time + runtime
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://app.mr5school.com
NEXT_PUBLIC_API_URL=https://api.mr5school.com

# Server-only on web task (Secrets Manager)
GEMINI_API_KEY=
WEATHER_API_KEY=

# Optional public client config
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_LIVEKIT_URL=

NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_YAHOO_VERIFICATION=

# =============================================================================
# BACKEND (ECS task: mr5-api)
# =============================================================================

NODE_ENV=production
PORT=5001
LOG_LEVEL=info

# Secrets Manager — required
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mr5school
JWT_SECRET=

# Secrets Manager — strongly recommended
CORS_ORIGIN=https://app.mr5school.com
CLIENT_URL=https://app.mr5school.com
CORS_EXTRA_ORIGINS=

JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_EXPIRES_IN=7d

AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

WEATHER_API_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.mr5school.com/api/auth/google/callback

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

EMAIL_USER=
EMAIL_PASS=
FROM_NAME=MR5 School
FROM_EMAIL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SUPPORT_EMAIL=

AVATHOR_SECRET_TOKEN=

# Legal / consent (IN CODE)
LEGAL_RECONSENT_ENFORCED=true
CONSENT_IP_LOGGING=true
CONSENT_IP_SALT=

# Logging (IN CODE)
LOG_TO_FILE=false

# Seed scripts — NEVER commit real passwords
# SEED_ADMIN_PASSWORD=
# SEED_USER_PASSWORD=

# =============================================================================
# AWS / GitHub Actions (not app runtime)
# =============================================================================

# AWS_REGION=us-east-1
# ECR_REPOSITORY_API=mr5-api
# ECR_REPOSITORY_WEB=mr5-web
# ECS_CLUSTER=mr5-production
# ECS_SERVICE_API=mr5-api
# ECS_SERVICE_WEB=mr5-web
