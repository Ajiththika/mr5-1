# =============================================================================
# MR5 School API — local development
# Copy to: Mr5-School-API-main/.env
# NEVER commit .env with real secrets
# =============================================================================

NODE_ENV=development
PORT=5001

# Required
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars

# MongoDB (optional locally — in-memory fallback if unset)
MONGO_URI=mongodb://127.0.0.1:27017/mr5school
# MONGODB_URI=  # alias for MONGO_URI

# Frontend URLs
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000
CORS_EXTRA_ORIGINS=

# Auth tokens
JWT_EXPIRE=15m
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI (at least one recommended for tutor features)
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama2

# Integrations (optional)
WEATHER_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AVATHOR_SECRET_TOKEN=

# Email — password reset (sendEmail.js)
EMAIL_USER=
EMAIL_PASS=
FROM_NAME=MR5 School
FROM_EMAIL=

# Email — support tickets (supportService.js)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SUPPORT_EMAIL=

# Legal / consent
LEGAL_RECONSENT_ENFORCED=true
CONSENT_IP_LOGGING=false
CONSENT_IP_SALT=

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false

# Seed scripts only (never use defaults in production)
# SEED_ADMIN_PASSWORD=
# SEED_USER_PASSWORD=
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Test only
# MONGO_URI_TEST=mongodb://127.0.0.1:27017/mr5-test
# TEST_STUDENT_EMAIL=student@mr5school.com
# TEST_STUDENT_PASSWORD=
# USE_REAL_MONGO_TEST=1

# Script only
# MESHY_API_KEY=
