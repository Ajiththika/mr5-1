# =============================================================================
# MR5 School API — PRODUCTION (placeholders only)
# =============================================================================
# DO NOT commit real values. Store secrets in AWS Secrets Manager and inject
# via ECS task definition / hosting provider secret references.
# Migration guide: docs/AWS_SECRETS_MIGRATION.md
# =============================================================================

NODE_ENV=production
PORT=5001
LOG_LEVEL=info

# --- Required (Secrets Manager: mr5-school/prod/mongo-uri) ---
MONGO_URI=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/mr5school?retryWrites=true&w=majority

# --- Required (Secrets Manager: mr5-school/prod/jwt-secret) ---
# Minimum 32 random bytes (base64 or hex). Rotate on compromise.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# --- CORS / client (non-secret; can be plain env) ---
CORS_ORIGIN=https://app.mr5school.com
CLIENT_URL=https://app.mr5school.com
CORS_EXTRA_ORIGINS=

JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_EXPIRES_IN=7d

# --- AI (Secrets Manager) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=REPLACE_ME
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# --- Integrations (Secrets Manager) ---
WEATHER_API_KEY=REPLACE_ME
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_CALLBACK_URL=https://app.mr5school.com/api/auth/google/callback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=REPLACE_ME
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=REPLACE_ME
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
EMAIL_USER=
EMAIL_PASS=REPLACE_ME
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=REPLACE_ME
SUPPORT_EMAIL=
AVATHOR_SECRET_TOKEN=REPLACE_ME

# --- Legal / consent ---
LEGAL_RECONSENT_ENFORCED=true
CONSENT_IP_LOGGING=false
CONSENT_IP_SALT=REPLACE_ME

LOG_TO_FILE=false

# Seed scripts only — never use in production runtime
# SEED_ADMIN_PASSWORD=
# SEED_USER_PASSWORD=
