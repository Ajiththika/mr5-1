# =============================================================================
# MR5 School API — environment template
# Copy to: .env (local) — never commit real secrets
# =============================================================================

# --- Required ------------------------------------------------------------------

NODE_ENV=development
PORT=5001

# MongoDB (MONGODB_URI is accepted as an alias)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/mr5school?retryWrites=true&w=majority

# Auth — min 32 chars recommended in production
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars

# --- Strongly recommended ----------------------------------------------------

# Frontend origin for CORS and OAuth redirects
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000
# Comma-separated extra allowed origins (e.g. AWS CloudFront URL during cutover)
CORS_EXTRA_ORIGINS=
CLIENT_URL=http://localhost:3000

# Access token lifetime (authService)
JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI providers (at least one recommended) -----------------------------------

AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama2

# --- Optional: integrations --------------------------------------------------

WEATHER_API_KEY=your_openweather_api_key

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

EMAIL_USER=
EMAIL_PASS=
FROM_NAME=MR5 School
FROM_EMAIL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SUPPORT_EMAIL=

AVATHOR_SECRET_TOKEN=

LOG_LEVEL=info

# Avatar route token expiry (separate from JWT_EXPIRE)
JWT_EXPIRES_IN=7d

# --- Test / CI only ----------------------------------------------------------
# MONGO_URI_TEST=mongodb://127.0.0.1:27017/mr5-test
# TEST_STUDENT_EMAIL=student@mr5school.com
# TEST_STUDENT_PASSWORD=
