# =============================================================================
# MR5 School API — environment template (all environments)
# =============================================================================
# Copy:  cp .env.example .env
# Production: use AWS Secrets Manager — see docs/AWS_SECRETS_MIGRATION.md
# =============================================================================

# --- Core ---
NODE_ENV=development
PORT=5001
LOG_LEVEL=info

# MongoDB (MONGODB_URI accepted as alias)
# Dev: omit to use in-memory MongoDB. Prod: Secrets Manager mr5-school/prod/mongo-uri
MONGO_URI=

# Auth — min 32 chars in production (Secrets Manager: mr5-school/prod/jwt-secret)
JWT_SECRET=REPLACE_WITH_DEV_ONLY_SECRET_MIN_32_CHARS

JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_EXPIRES_IN=7d

# Frontend origin for CORS and OAuth redirects
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000
CORS_EXTRA_ORIGINS=

# --- AI providers (at least one recommended for AI features) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama2

# --- Optional integrations ---
WEATHER_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

EMAIL_USER=
EMAIL_PASS=
FROM_NAME=MR5 School
FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SUPPORT_EMAIL=

AVATHOR_SECRET_TOKEN=

# Legal / consent
LEGAL_RECONSENT_ENFORCED=true
CONSENT_IP_LOGGING=false
CONSENT_IP_SALT=

LOG_TO_FILE=false

# --- Test / CI only ---
# MONGO_URI_TEST=mongodb://127.0.0.1:27017/mr5-test
# TEST_STUDENT_EMAIL=student@mr5school.com
# TEST_STUDENT_PASSWORD=

# --- Seed scripts only (never production defaults) ---
# SEED_ADMIN_PASSWORD=
# SEED_USER_PASSWORD=
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
