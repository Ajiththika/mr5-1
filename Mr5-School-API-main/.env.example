# =============================================================================
# MR5 School API — enterprise environment template
# =============================================================================
# Setup:  cp .env.example .env
# Never commit .env. Production: AWS Secrets Manager (docs/AWS_SECRETS_MIGRATION.md)
# =============================================================================

# --- Core ---
NODE_ENV=development
# Dev: 5001 on macOS (5000 = AirPlay). Production/Docker: 5000
PORT=5001
LOG_LEVEL=info

# MongoDB (MONGODB_URI accepted as alias)
# Dev: leave empty for in-memory MongoDB + auto-seed demo users
# Prod: required — mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mr5school
MONGO_URI=

# Auth — min 32 chars in production
JWT_SECRET=REPLACE_WITH_DEV_ONLY_SECRET_MIN_32_CHARS
JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_EXPIRES_IN=7d

# Frontend (CORS + OAuth)
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000
CORS_EXTRA_ORIGINS=

# --- AI ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama2

# --- Integrations (optional) ---
WEATHER_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AVATHOR_SECRET_TOKEN=

# --- Email ---
EMAIL_USER=
EMAIL_PASS=
FROM_NAME=MR5 School
FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SUPPORT_EMAIL=

# --- Legal / consent ---
LEGAL_RECONSENT_ENFORCED=true
CONSENT_IP_LOGGING=false
CONSENT_IP_SALT=
LOG_TO_FILE=false

# --- Production overrides (set NODE_ENV=production + Secrets Manager) ---
# PORT=5000
# CORS_ORIGIN=https://app.mr5school.com
# CLIENT_URL=https://app.mr5school.com
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mr5school
# JWT_SECRET=<32+ char secret from Secrets Manager>
