# ==============================================
# Vercel Environment Variables for Frontend
# Add these in Vercel Dashboard > Settings > Environment Variables
# ==============================================

# API URL - Set this to your backend Vercel deployment URL
NEXT_PUBLIC_API_URL=https://mr5-school-api.vercel.app

# Gemini AI API Key (get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Stripe Keys for payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# Optional: Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
