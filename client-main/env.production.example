# =============================================================================
# MR5 School Web — production reference (Vercel or ECS)
# =============================================================================
# For Vercel: add these in Dashboard → Settings → Environment Variables
# For local:  use .env.local.example instead
# Full guide: docs/VERCEL_ENVIRONMENT.md
# =============================================================================

# --- Public (browser-safe) ---
NEXT_PUBLIC_SITE_URL=https://app.mr5school.com
NEXT_PUBLIC_API_URL=https://api.mr5school.com

# --- Server-only (NEVER use NEXT_PUBLIC_ prefix) ---
GEMINI_API_KEY=REPLACE_ME
WEATHER_API_KEY=REPLACE_ME
OPENAI_API_KEY=

# --- Optional public client config ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_LIVEKIT_URL=

# CDN (URLs only)
# NEXT_PUBLIC_CDN_BASE_URL=https://cdn.mr5school.com

# SEO verification
# NEXT_PUBLIC_GOOGLE_VERIFICATION=
# NEXT_PUBLIC_YANDEX_VERIFICATION=
# NEXT_PUBLIC_YAHOO_VERIFICATION=

NODE_ENV=production
