# =============================================================================
# MR5 School — Git hardening
# =============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
out/
.next/
.turbo/
.vercel/

# Environment & secrets — NEVER commit real values
.env
.env.*
!.env.example
!.env.local.example
!.env.production.example
.envcopy
.env.local
.env.development.local
.env.test.local
.env.production.local

# Client-specific (allow examples only)
client-main/.env
client-main/.env.*
!client-main/.env.local.example
!client-main/env.production.example

# API-specific
Mr5-School-API-main/.env
Mr5-School-API-main/.env.*
!Mr5-School-API-main/.env.example
!Mr5-School-API-main/.env.production.example

# Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
test_output.txt

# Test & coverage
coverage/
.nyc_output/
playwright-report/
test-results/
*.lcov

# IDE / OS
.idea/
.vscode/*
!.vscode/extensions.json
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Security scan artifacts
.trivy/
gitleaks-report.json
.secrets.baseline

# Local backups & sensitive artifacts
backups/
cookies.txt
*.pem
*.key
*.p12
*.pfx
id_rsa*
*.bak

# Cache
.cache/
.parcel-cache/
.eslintcache

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Docker local overrides
docker-compose.override.yml

# Terraform state (if added later)
*.tfstate
*.tfstate.*
.terraform/
