{
  "family": "mr5-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/mr5-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/mr5-api-task-role",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/mr5-api:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 5001, "protocol": "tcp" }],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "5001" },
        { "name": "LOG_LEVEL", "value": "info" }
      ],
      "secrets": [
        { "name": "MONGO_URI", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:mr5/production/api:MONGO_URI::" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:mr5/production/api:JWT_SECRET::" },
        { "name": "CORS_ORIGIN", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:mr5/production/api:CORS_ORIGIN::" },
        { "name": "CLIENT_URL", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:mr5/production/api:CLIENT_URL::" },
        { "name": "GEMINI_API_KEY", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:mr5/production/api:GEMINI_API_KEY::" },
        { "name": "STRIPE_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:mr5/production/api:STRIPE_SECRET_KEY::" },
        { "name": "STRIPE_WEBHOOK_SECRET", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:mr5/production/api:STRIPE_WEBHOOK_SECRET::" },
        { "name": "CLOUDINARY_API_SECRET", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:mr5/production/api:CLOUDINARY_API_SECRET::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mr5-api",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://127.0.0.1:5001/ready || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
